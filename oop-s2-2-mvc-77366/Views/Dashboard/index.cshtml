@model FoodInspectionService.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<form method="get" asp-action="Index" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Town</label>
        <select name="town" class="form-select">
            <option value="">All</option>
            @foreach (var town in Model.Towns)
            {
                if (Model.SelectedTown == town)
                {
                    <option value="@town" selected>@town</option>
                }
                else
                {
                    <option value="@town">@town</option>
                }
            }
        </select>
    </div>

    <div class="col-md-4">
        <label class="form-label">Risk Rating</label>
        <select name="riskRating" class="form-select">
            <option value="">All</option>
            @foreach (var risk in Model.RiskRatings)
            {
                if (Model.SelectedRiskRating == risk)
                {
                    <option value="@risk" selected>@risk</option>
                }
                else
                {
                    <option value="@risk">@risk</option>
                }
            }
        </select>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Apply Filters</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card text-bg-light border-primary">
            <div class="card-body">
                <h5 class="card-title">Inspections This Month</h5>
                <p class="card-text fs-2">@Model.InspectionsThisMonth</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card text-bg-light border-danger">
            <div class="card-body">
                <h5 class="card-title">Failed Inspections This Month</h5>
                <p class="card-text fs-2">@Model.FailedInspectionsThisMonth</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card text-bg-light border-warning">
            <div class="card-body">
                <h5 class="card-title">Overdue Open Follow-Ups</h5>
                <p class="card-text fs-2">@Model.OverdueOpenFollowUps</p>
            </div>
        </div>
    </div>
</div>

